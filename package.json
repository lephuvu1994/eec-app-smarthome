{
  "name": "sensa-smart",
  "version": "0.0.1",
  "private": true,
  "main": "expo-router/entry",
  "packageManager": "yarn@4.9.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lephuvu1994/"
  },
  "reanimated": {
    "staticFeatureFlags": {
      "ENABLE_SHARED_ELEMENT_TRANSITIONS": true
    }
  },
  "scripts": {
    "eas-build-pre-install": "corepack enable",
    "start": "expo start",
    "prebuild": "node scripts/patch-vlc-for-prebuild.js && yarn expo prebuild",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios-device": "expo run:ios --device 00008030-001150AC0AA0802E",
    "ios-device2": "expo run:ios --device 00008140-000475AE0252801C",
    "web": "expo start --web",
    "xcode": "xed -b ios",
    "doctor": "npx expo-doctor@latest",
    "preinstall": "npx only-allow yarn",
    "start:preview": "cross-env EXPO_PUBLIC_APP_ENV=preview yarn start",
    "prebuild:preview": "cross-env EXPO_PUBLIC_APP_ENV=preview STRICT_ENV_VALIDATION=1 yarn prebuild",
    "prebuild:development": "cross-env EXPO_PUBLIC_APP_ENV=development STRICT_ENV_VALIDATION=1 yarn prebuild",
    "android:preview": "cross-env EXPO_PUBLIC_APP_ENV=preview yarn android",
    "ios:preview": "cross-env EXPO_PUBLIC_APP_ENV=preview yarn ios",
    "start:production": "cross-env EXPO_PUBLIC_APP_ENV=production yarn start",
    "prebuild:production": "cross-env EXPO_PUBLIC_APP_ENV=production STRICT_ENV_VALIDATION=1 yarn prebuild",
    "android:production": "cross-env EXPO_PUBLIC_APP_ENV=production yarn android",
    "ios:production": "cross-env EXPO_PUBLIC_APP_ENV=production yarn ios",
    "build:development:ios": "eas build --profile development --platform ios",
    "build:development:android": "eas build --profile development --platform android",
    "build:preview:ios": "eas build --profile preview --platform ios",
    "build:preview:android": "eas build --profile preview --platform android",
    "build:production:ios": "eas build --profile production --platform ios",
    "build:production:android": "eas build --profile production --platform android",
    "postinstall": "patch-package && node scripts/patch-vlc-for-prebuild.js",
    "prepare": "husky",
    "app-release": "cross-env SKIP_BRANCH_PROTECTION=true np --no-publish --no-cleanup --no-release-draft",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noemit",
    "lint:translations": "eslint ./src/translations/ --fix --ext .json",
    "test": "jest",
    "check-all": "yarn lint && yarn type-check && yarn lint:translations && yarn test",
    "test:ci": "yarn test --coverage",
    "test:watch": "yarn test --watch",
    "install-maestro": "curl -Ls 'https://get.maestro.mobile.dev' | bash",
    "e2e-test": "maestro test .maestro/ -e APP_ID=com.obytes.development"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/metro-runtime": "~55.0.6",
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@quidone/react-native-wheel-picker": "^1.6.4",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-menu/menu": "^2.0.0",
    "@react-navigation/drawer": "7.9.4",
    "@react-navigation/native": "^7.1.33",
    "@shopify/flash-list": "2.0.2",
    "@shopify/react-native-skia": "2.4.18",
    "@tanstack/react-form": "^1.27.7",
    "@tanstack/react-query": "^5.90.19",
    "@tanstack/zod-form-adapter": "^0.42.1",
    "@types/papaparse": "5.3.15",
    "axios": "^1.13.2",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "expo": "^55.0.8",
    "expo-blur": "~55.0.10",
    "expo-build-properties": "~55.0.10",
    "expo-camera": "~55.0.11",
    "expo-clipboard": "~55.0.9",
    "expo-constants": "~55.0.9",
    "expo-crypto": "~55.0.10",
    "expo-dev-client": "~55.0.18",
    "expo-device": "~55.0.10",
    "expo-document-picker": "~55.0.9",
    "expo-font": "~55.0.4",
    "expo-glass-effect": "^55.0.8",
    "expo-haptics": "~55.0.9",
    "expo-image": "~55.0.6",
    "expo-image-manipulator": "~55.0.11",
    "expo-image-picker": "~55.0.13",
    "expo-linear-gradient": "~55.0.9",
    "expo-linking": "~55.0.8",
    "expo-localization": "~55.0.9",
    "expo-network": "~55.0.9",
    "expo-notifications": "~55.0.14",
    "expo-router": "~55.0.7",
    "expo-screen-orientation": "~55.0.9",
    "expo-speech": "~55.0.9",
    "expo-speech-recognition": "3.0.0",
    "expo-splash-screen": "~55.0.12",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "^55.0.5",
    "expo-system-ui": "~55.0.10",
    "expo-updates": "~55.0.15",
    "i18next": "^25.8.0",
    "lodash.isequal": "^4.5.0",
    "lodash.memoize": "^4.1.2",
    "moti": "^0.30.0",
    "mqtt": "^5.15.1",
    "papaparse": "5.5.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-error-boundary": "^6.1.0",
    "react-i18next": "^16.5.3",
    "react-native": "0.83.4",
    "react-native-ble-manager": "^12.4.4",
    "react-native-edge-to-edge": "^1.7.0",
    "react-native-flash-message": "^0.4.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-hash": "3.0.3",
    "react-native-ios-context-menu": "^3.2.1",
    "react-native-ios-utilities": "^5.2.0",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-mmkv": "^4.3.0",
    "react-native-nitro-modules": "^0.35.2",
    "react-native-pager-view": "8.0.0",
    "react-native-popover-view": "^6.1.0",
    "react-native-qrcode-svg": "6.3.20",
    "react-native-quick-base64": "^2.2.2",
    "react-native-quick-crypto": "^1.0.16",
    "react-native-reanimated": "4.2.1",
    "react-native-restart": "0.0.27",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-sortables": "^1.9.4",
    "react-native-svg": "15.15.3",
    "react-native-tab-view": "^4.2.2",
    "react-native-tcp-socket": "^6.4.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-uuid": "2.0.2",
    "react-native-vlc-media-player": "1.0.98",
    "react-native-web": "^0.21.2",
    "react-native-wifi-reborn": "^4.13.6",
    "react-native-worklets": "0.7.4",
    "react-query-kit": "^3.3.2",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "uniwind": "^1.2.4",
    "useragent-parser-js": "1.0.3",
    "zeego": "^3.0.6",
    "zod": "^4.3.5",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.2.0",
    "@babel/core": "^7.28.6",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@dev-plugins/react-query": "^0.4.0",
    "@eslint-react/eslint-plugin": "^2.7.2",
    "@expo/cli": "54.0.22",
    "@expo/config": "^55.0.7",
    "@tailwindcss/cli": "^4.0.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/i18n-js": "^4.0.1",
    "@types/invariant": "^2.2.37",
    "@types/jest": "^29.5.14",
    "@types/lodash.isequal": "^4.5.8",
    "@types/lodash.memoize": "^4.1.9",
    "@types/react": "~19.2.10",
    "babel-plugin-module-resolver": "^5.0.2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-better-tailwindcss": "^4.0.1",
    "eslint-plugin-i18n-json": "^4.0.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-testing-library": "^7.15.4",
    "eslint-plugin-unicorn": "^62.0.0",
    "figma-mcp-server": "^2.1.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.11",
    "jest-junit": "^16.0.0",
    "lint-staged": "^16.2.7",
    "np": "^10.3.0",
    "patch-package": "^8.0.0",
    "tailwindcss": "4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false,
        "exclude": [
          "react-native-restart",
          "react-native-vlc-media-player",
          "react-native-tcp-socket"
        ]
      }
    },
    "install": {
      "exclude": [
        "eslint-config-expo",
        "react-native-worklets"
      ]
    }
  }
}
